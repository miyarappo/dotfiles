#!/bin/sh
set -eu

branch="$(git symbolic-ref --quiet --short HEAD || true)"

# ① グローバルルール（main 禁止 / 許可リストは除外）
ALLOW_MAIN_REPOS="dotfiles"

repo_name="$(basename "$(git rev-parse --show-toplevel 2>/dev/null)" 2>/dev/null || true)"

if [ "$branch" = "main" ]; then
  case " $ALLOW_MAIN_REPOS " in
    *" $repo_name "*)
      ;;
    *)
      echo "❌ main branch commits are blocked by a global Git hook"
      exit 1
      ;;
  esac
fi

# ② repo 固有 hook があれば実行
if [ -x .githooks/pre-commit ]; then
  ./.githooks/pre-commit
fi
